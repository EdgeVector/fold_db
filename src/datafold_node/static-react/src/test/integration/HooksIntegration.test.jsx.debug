/**
 * Debug version of the failing test with logging to validate diagnosis
 */
import React from 'react';
import { renderHook, act, waitFor } from '@testing-library/react';
import { describe, it, expect, beforeEach, vi } from 'vitest';
import { useApprovedSchemas, useFormValidation } from '../../hooks/index.js';
import { renderHookWithRedux } from '../utils/testStore.jsx';

describe('HooksIntegration Debug', () => {
  beforeEach(() => {
    vi.clearAllMocks();
    global.fetch = vi.fn();
    global.console = {
      ...console,
      log: vi.fn(),
      warn: vi.fn(),
      error: vi.fn()
    };
  });

  it('should handle error states across integrated hooks - DEBUG', async () => {
    // Track fetch calls and timing
    const fetchCalls = [];
    const startTime = Date.now();
    
    // Mock fetch failure with detailed logging
    fetch.mockImplementation(() => {
      const callTime = Date.now() - startTime;
      fetchCalls.push(callTime);
      console.log(`FETCH CALL ${fetchCalls.length} at ${callTime}ms`);
      return Promise.reject(new Error('Network error'));
    });

    console.log('=== STARTING TEST ===');
    
    // Create hook with Redux store
    const { result: schemasResult, store } = renderHookWithRedux(() => useApprovedSchemas());
    
    console.log('=== HOOK RENDERED ===');
    console.log('Initial loading state:', schemasResult.current.isLoading);
    console.log('Initial cache info:', store.getState().schemas.cache);
    console.log('Initial lastFetched:', store.getState().schemas.lastFetched);
    
    // Monitor state changes
    let stateChanges = 0;
    const unsubscribe = store.subscribe(() => {
      stateChanges++;
      const state = store.getState();
      const elapsed = Date.now() - startTime;
      console.log(`STATE CHANGE ${stateChanges} at ${elapsed}ms:`, {
        loading: state.schemas.loading.fetch,
        error: state.schemas.errors.fetch,
        lastFetched: state.schemas.lastFetched
      });
    });

    // Wait for loading to be false with extended timeout
    try {
      await waitFor(() => {
        const elapsed = Date.now() - startTime;
        console.log(`WAIT CHECK at ${elapsed}ms - Loading: ${schemasResult.current.isLoading}`);
        expect(schemasResult.current.isLoading).toBe(false);
      }, { timeout: 10000, interval: 500 }); // Extended timeout for retry logic
    } catch (error) {
      const elapsed = Date.now() - startTime;
      console.log(`WAIT FAILED after ${elapsed}ms`);
      console.log('Final loading state:', schemasResult.current.isLoading);
      console.log('Final error state:', schemasResult.current.error);
      console.log('Total fetch calls:', fetchCalls.length);
      console.log('Fetch call timings:', fetchCalls);
      throw error;
    } finally {
      unsubscribe();
    }

    const elapsed = Date.now() - startTime;
    console.log(`=== TEST COMPLETED in ${elapsed}ms ===`);
    console.log('Total fetch calls:', fetchCalls.length);
    console.log('Final state:', {
      loading: schemasResult.current.isLoading,
      error: schemasResult.current.error,
      schemas: schemasResult.current.approvedSchemas
    });

    expect(schemasResult.current.error).toContain('Failed to fetch schemas');
    expect(schemasResult.current.approvedSchemas).toEqual([]);
  });
});
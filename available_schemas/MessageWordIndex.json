{
  "name": "MessageWordIndex",
  "key": {
    "hash_field": "word",
    "range_field": "sent_at"
  },
  "transform_fields": {
    "word": "Message.map().content.split_by_word().map()",
    "sent_at": "Message.map().sent_at",
    "message_id": "Message.map().message_id",
    "conversation_id": "Message.map().conversation_id",
    "sender_id": "Message.map().sender_id",
    "recipient_id": "Message.map().recipient_id",
    "content": "Message.map().content",
    "message_type": "Message.map().message_type"
  }
}


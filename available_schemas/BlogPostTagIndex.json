{
  "name": "BlogPostTagIndex",
  "key": {
    "hash_field": "tag",
    "range_field": "publish_date"
  },
  "transform_fields": {
    "tag": "BlogPost.map().tags.split_array().map()",
    "publish_date": "BlogPost.map().publish_date",
    "title": "BlogPost.map().title",
    "author": "BlogPost.map().author",
    "content": "BlogPost.map().content"
  }
}


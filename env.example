# DataFold Environment Variables
# Copy this file to .env and fill in your actual values

# OpenRouter API Configuration (REQUIRED for AI ingestion)
# Note: The code looks for FOLD_OPENROUTER_API_KEY, not OPENROUTER_API_KEY
export FOLD_OPENROUTER_API_KEY="your-openrouter-api-key-here"

# Optional OpenRouter Configuration
export OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
export OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Ingestion Configuration
export INGESTION_ENABLED="true"
export INGESTION_MAX_RETRIES="3"
export INGESTION_TIMEOUT_SECONDS="30"
export INGESTION_AUTO_EXECUTE="true"
export INGESTION_DEFAULT_TRUST_DISTANCE="0"

# Configuration Directory
export DATAFOLD_CONFIG_DIR="./config"

# Logging
export DATAFOLD_LOG_LEVEL="info"
